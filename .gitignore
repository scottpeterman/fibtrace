## ─── fibtrace-specific scratch ──────────────────────────────────

# Stale source bundles
fibtrace.zip
fibtrace*.zip

# Dev-workflow dumps (keep locally, don't ship)
debug.json
drt_databank.json

# Inventory outputs from build_hosts.py
hosts.txt
hosts_*.txt
ports.txt

# Raw lab captures — sanitize before committing to examples/
lab_*.json
qfx*.json
tor*.json

# Pre-sanitization trace scratch at the repo root
/*.graph.json
/*.trace.json

# Sanitized outputs — commit deliberately to examples/, not by accident
*_san.json
*_sanitized.json
*.sanitized.json

# Screenshot dumps landing at repo root (GNOME default naming)
/Screenshot*.png
/Screenshot*.gif

# Common log files
*.log
